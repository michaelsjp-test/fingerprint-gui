# Udev rules for Fingerprint-GUI (libfprint devices)

# Goodix fingerprint scanners
SUBSYSTEM=="usb", ATTRS{idVendor}=="27c6", ATTRS{idProduct}=="6594", \
  MODE="0660", GROUP="plugdev", \
  ENV{FINGERPRINT_GUI_DRIVER}="Goodix Fingerprint Device"

# General libfprint device rule - covers most fingerprint scanners supported by libfprint
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="AuthenTec*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Digital*Persona*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Validity*Sensors*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="STMicroelectronics*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Synaptics*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Elan*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="FocalTech*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Goodix*", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ENV{ID_VENDOR}=="Next*Biometrics*", MODE="0660", GROUP="plugdev"

# Additional Goodix devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="27c6", ATTRS{idProduct}=="5110", MODE="0660", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="27c6", ATTRS{idProduct}=="5117", MODE="0660", GROUP="plugdev"
